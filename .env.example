# Resend API key — get one at https://resend.com
RESEND_API_KEY=

# Email destination for contact form submissions
CONTACT_TO_EMAIL=studio.motian@gmail.com

# Verified sender domain on Resend (e.g. notifications@studio-motian.com)
# For local testing you can use Resend's onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Cloudflare Turnstile (봇 방어) — https://dash.cloudflare.com → Turnstile에서 위젯 생성
# 둘 다 비어 있으면 Turnstile은 비활성(폼은 기존대로 동작). 둘 다 채우면 검증이 강제됨.
# 사이트키(공개, 클라이언트 노출용) — NEXT_PUBLIC_ 접두사 필수
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# 시크릿키(서버 전용, 절대 공개 금지)
TURNSTILE_SECRET_KEY=

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX). 비어 있으면 분석 비활성.
NEXT_PUBLIC_GA_ID=

# 검색엔진 소유확인 코드 — 등록 후 발급값. 비어 있으면 인증 메타 미출력.
# Google Search Console (https://search.google.com/search-console)
GOOGLE_SITE_VERIFICATION=
# 네이버 서치어드바이저 (https://searchadvisor.naver.com)
NAVER_SITE_VERIFICATION=
