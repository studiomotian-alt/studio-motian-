# Resend API key — get one at https://resend.com
RESEND_API_KEY=

# Email destination for contact form submissions
CONTACT_TO_EMAIL=studio.motian@gmail.com

# Verified sender domain on Resend (e.g. notifications@studio-motian.com)
# For local testing you can use Resend's onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev

# 자체 방문 통계 수집 엔드포인트 — 관리자 대시보드의 /api/ingest 전체 URL.
# 예: https://gip-motian-admin.vercel.app/api/ingest — 비어 있으면 비콘 비활성(전송·렌더 없음).
NEXT_PUBLIC_ANALYTICS_ENDPOINT=
